APP_NAME=DevClub
APP_ENV=local
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=devclub
DB_USERNAME=root
DB_PASSWORD=root

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@example.com

# Third party keys (placeholders)
STRIPE_KEY=
STRIPE_SECRET=
CRMS_API_KEY=

# Runtime config (frontend)
AUTOSAVE_DELAY_MS=800
PER_PAGE_SHORT=5
PER_PAGE_MEDIUM=10
PER_PAGE_LARGE=15
