UI_AUTOSAVE_DELAY_MS=700




# Proveedor base local (MMDB)
IP_COUNTRY_PROVIDER=iplocate

# (Opcional) URL de descarga del .mmdb de IPLocate (si no pones nada, usa el default del config)
IP_COUNTRY_IPLOCATE_URL=https://cdn.jsdelivr.net/npm/@ip-location-db/iplocate-country-mmdb/iplocate-country.mmdb

# Máxima “edad” permitida del archivo local antes de re-descargar (días)
IP_COUNTRY_TTL_DAYS_IPLOCATE=7

# Caché del resultado IP->ISO2 (segundos)
IP_COUNTRY_CACHE_TTL_SECONDS=86400

# ISO-2 (ej: CL, CO, US). Si lo dejas vacío, el fallback será null.
IP_COUNTRY_FALLBACK_ISO2=CL


# Cómo determinar la IP del cliente:
# - request_ip    => $request->ip() (Laravel; depende de trusted proxies si hay)
# - remote_addr   => REMOTE_ADDR (directo del servidor web)
# - header        => un header específico (X-Forwarded-For, X-Real-IP, etc.)
# - cloudflare    => CF-Connecting-IP (si estás detrás de Cloudflare)
# - auto          => usa una lista de precedencia de headers y cae a REMOTE_ADDR
IP_COUNTRY_IP_SOURCE=remote_addr



# Si true, loguea también los registros aplicados (aprobados)
CAPITADOS_BATCH_ITEM_LOG_APPLIED=true

# Si true, loguea los registros rechazados
CAPITADOS_BATCH_ITEM_LOG_REJECTED=true

# Si true, loguea registros marcados como incongruencia
CAPITADOS_BATCH_ITEM_LOG_INCONGRUENCE=true

# Si true, loguea registros duplicados
CAPITADOS_BATCH_ITEM_LOG_DUPLICATED=true

MODULE_USERS=true
MODULE_PLANTILLAS=true
MODULE_ROLES=false
MODULE_COMPANY=true
MODULE_UNITS=false
MODULE_CONFIG=true
MODULE_COUNTRY=true
MODULE_COUNTRY_ZONES=true
MODULE_COVERAGE=true
MODULE_PRODUCTOS=true

# Rutas locales de almacenamiento y branding
APP_STORAGE_DIR="../storage/gfa"
APP_BRANDING=gfa
